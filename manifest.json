{
  "manifest_version": 3,
  "name": "Lesan Blur",
  "version": "1.0.0",
  "description": "Make social media safer by blurring bad words in English and Arabic.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "*://*.youtube.com/*",
    "*://*.instagram.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.google.com/*",
    "*://*.reddit.com/*",
    "*://*.tiktok.com/*"
    
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.google.com/*",
        "*://*.reddit.com/*",
        "*://*.tiktok.com/*",
        "*://*.linkedin.com/*"
      ],
      "css": ["content.css"],
      "js": ["words.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lesan Blur"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
